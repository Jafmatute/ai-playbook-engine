# AI Playbook Engine — Configuration
#
# Copy this file to configure environment variables.
# The engine reads these from the actual environment, NOT from a .env file.

# Environment: development, test, or production (default: development)
# AI_PLAYBOOK_ENGINE_ENV=development

# PostgreSQL connection string (required for database commands)
# AI_PLAYBOOK_ENGINE_DATABASE_URL=postgresql://user:password@localhost:5432/ai_playbook_engine

# Default workspace ID (required for most commands after initialization)
# AI_PLAYBOOK_ENGINE_WORKSPACE_ID=

# CLI output format: human or json (default: human)
# AI_PLAYBOOK_ENGINE_CLI_OUTPUT=human
