{
  "name": "ai-playbook-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Engine for consuming, processing and executing the AI Engineering Playbook.",
  "license": "UNLICENSED",
  "packageManager": "pnpm",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "pnpm --parallel -r --if-present dev",
    "test": "pnpm -r --if-present test",
    "test:unit": "pnpm -r --if-present test:unit",
    "test:integration": "pnpm -r --if-present test:integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --build --pretty",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r --if-present clean",
    "validate": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "ci": "pnpm format && pnpm format:check && pnpm lint && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
